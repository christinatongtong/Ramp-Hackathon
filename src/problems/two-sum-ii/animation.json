{
  "structure": {
    "type": "array",
    "inputKey": "numbers",
    "layout": "horizontal",
    "showIndices": true
  },
  "theme": {
    "preset": "generic_grid",
    "name": "derpy-two-pointer-number-lane",
    "palette": {
      "sky": "#BDE7FF",
      "ground": "#DCE6F2",
      "accent": "#FFD166"
    },
    "camera": {
      "mode": "isometric",
      "position": [
        0.0,
        6.0,
        12.0
      ],
      "target": [
        0.0,
        0.5,
        0.0
      ]
    },
    "props": [
      {
        "primitive": "goofy_cloud",
        "placement": "sky",
        "count": 2
      },
      {
        "primitive": "sign",
        "placement": "back",
        "count": 1
      }
    ],
    "timeSystem": {
      "mode": "static",
      "advanceOn": "none"
    }
  },
  "entities": {
    "numeric_value_2": {
      "primitive": "array_block",
