      "color": "#6EA8FE",
      "label": "9",
      "idleAnimation": "gentle_bounce",
      "expression": "wide-eyed"
    },
    "numeric_value_11": {
      "primitive": "array_block",
      "variant": "chunky_number",
      "color": "#6EA8FE",
      "label": "11",
