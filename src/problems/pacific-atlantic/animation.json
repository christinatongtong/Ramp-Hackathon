{
  "world": {
    "preset": "island",
    "theme": "Derpy reverse multi-source ocean reachability across a labeled elevation grid",
    "sceneType": "grid",
    "palette": {
      "sky": "#BDEBFF",
      "ground": "#D9C88F",
      "accent": "#FFD166"
    },
    "camera": {
      "mode": "top_down",
      "position": [
        0.0,
        12.0,
        0.0
      ],
      "target": [
        0.0,
        0.0,
        0.0
      ]
    },
    "props": [
      {
        "primitive": "goofy_cloud",
        "placement": "sky",
        "count": 2
      },
      {
        "primitive": "sign",
        "placement": "back",
        "count": 1
      }
    ],
    "timeSystem": {
      "mode": "static",
      "advanceOn": "none"
    }
  },
  "entities": {
    "height_1": {
      "primitive": "height_block",
      "variant": "chunky_low_terrace",
      "color": "#D8F3DC",
      "label": "1",
      "idleAnimation": "none",
      "expression": null
    },
    "height_2": {
      "primitive": "height_block",
      "variant": "chunky_terrace_2",
      "color": "#B7E4C7",
      "label": "2",
      "idleAnimation": "none",
      "expression": null
    },
    "height_3": {
      "primitive": "height_block",
      "variant": "chunky_terrace_3",
      "color": "#95D5B2",
      "label": "3",
      "idleAnimation": "none",
      "expression": null
    },
    "height_4": {
      "primitive": "height_block",
      "variant": "chunky_terrace_4",
      "color": "#74C69D",
      "label": "4",
      "idleAnimation": "none",
      "expression": null
    },
    "height_5": {
      "primitive": "height_block",
      "variant": "chunky_terrace_5",
      "color": "#52B788",
      "label": "5",
      "idleAnimation": "none",
      "expression": null
    },
    "height_6": {
      "primitive": "height_block",
      "variant": "chunky_terrace_6",
      "color": "#40916C",
      "label": "6",
      "idleAnimation": "none",
      "expression": null
    },
    "height_7": {
      "primitive": "height_block",
      "variant": "chunky_high_terrace",
      "color": "#2D6A4F",
      "label": "7",
      "idleAnimation": "none",
      "expression": null
    }
  },
  "eventBindings": {
    "init": {
      "effect": "cell_pulse",
      "durationMs": 500,
      "color": "#FFFFFF",
      "explanation": "Reveal the unchanged height map; every labeled block represents permanent elevation data.",
      "targetReaction": "none",
      "camera": "none"
    },
    "visit": {
      "effect": "bounce",
      "durationMs": 180,
      "color": "#FFD166",
      "explanation": "Briefly identify the cell currently accepted by the trace's reverse search from the named ocean.",
      "targetReaction": "brief_focus",
      "camera": "none"
    },
    "reachability_update": {
      "effect": "cell_pulse",
      "durationMs": 220,
      "color": "#66D9FF",
      "explanation": "Make the emitted ocean-specific reachability overlay visible without replacing the cell's elevation.",
      "targetReaction": "brief_focus",
      "camera": "none"
    },
    "path_mark": {
      "effect": "path_reveal",
      "durationMs": 400,
      "color": "#FFE066",
      "explanation": "Highlight a trace-marked answer cell that is reachable from both ocean searches; this is an answer set, not a reconstructed route.",
      "targetReaction": "brief_focus",
      "camera": "none"
    },
    "done": {
      "effect": "result_reveal",
      "durationMs": 800,
      "color": "#FFD166",
      "explanation": "Reveal the completed set of cells marked by the trace as reaching both oceans.",
      "targetReaction": "none",
      "camera": "brief_focus"
    }
  },
  "resultChoreography": {
    "success": {
      "effect": "confetti",
      "entityReaction": "bad_dance",
      "explanation": "Celebrate while leaving all both-ocean answer highlights and elevation labels unobscured."
    },
    "failure": {
      "effect": "failure_deflate",
      "entityReaction": "confused_stare",
      "explanation": "Gently deflate the presentation while preserving the final grid for inspection."
    }
  },
  "intro": [
    {
      "action": "show_title",
      "durationMs": 900,
      "text": "Pacific Atlantic Water Flow: Reverse Reachability"
    },
    {
      "action": "show_grid",
      "durationMs": 1000,
      "text": "Each chunky labeled block is a permanent elevation; larger labels mean higher ground."
    },
    {
      "action": "highlight_sources",
      "durationMs": 1200,
      "text": "Pacific search sources lie along the top and left borders; Atlantic search sources lie along the bottom and right borders."
    },
    {
      "action": "camera_pan",
      "durationMs": 700,
      "text": "Watch each ocean's reverse search accept equal-or-higher neighboring cells, then reveal the overlap."
    }
  ]
}
