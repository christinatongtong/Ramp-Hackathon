{
  "structure": {
    "type": "binary_tree",
    "inputKey": "root",
    "layout": "layered"
  },
  "theme": {
    "preset": "generic_grid",
    "name": "derpy-mirror-tree-workshop",
    "palette": {
      "sky": "#CDEBFF",
      "ground": "#E7E1D3",
      "accent": "#FFB703"
    },
    "camera": {
      "mode": "top_down",
      "position": [
        0.0,
        10.0,
        12.0
      ],
      "target": [
        0.0,
        0.0,
        0.0
      ]
    },
    "props": [
      {
        "primitive": "goofy_cloud",
        "placement": "sky",
        "count": 2
      },
      {
        "primitive": "sign",
        "placement": "back",
        "count": 1
      }
    ],
    "timeSystem": {
      "mode": "static",
      "advanceOn": "none"
    }
  },
  "entities": {
    "node_value_1": {
      "primitive": "tree_node",
