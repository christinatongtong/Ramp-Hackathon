      "idleAnimation": "gentle_bounce",
      "expression": "wide_eyed"
    },
    "node_value_3": {
      "primitive": "tree_node",
      "variant": "chunky_numbered_node",
      "color": "#7DD3FC",
      "label": "3",
      "idleAnimation": "gentle_bounce",
      "expression": "goofy_grin"
    },
    "node_value_4": {
      "primitive": "tree_node",
      "variant": "chunky_numbered_node",
      "color": "#7DD3FC",
