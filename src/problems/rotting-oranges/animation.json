{
  "world": {
    "preset": "farm",
    "theme": "derpy-orange-grove",
    "sceneType": "grid",
    "palette": {
      "sky": "#87CEEB",
      "ground": "#6FCF4A",
      "accent": "#FFD93D"
    },
    "camera": {
      "mode": "isometric",
      "position": [8.0, 10.0, 8.0],
      "target": [0.0, 0.0, 0.0]
    },
    "props": [
      {
        "primitive": "tree",
        "placement": "perimeter",
        "count": 8
      },
      {
        "primitive": "goofy_cloud",
        "placement": "sky",
        "count": 3
      },
      {
        "primitive": "fence",
        "placement": "back",
        "count": 1
      }
    ],
    "timeSystem": {
      "mode": "day_night",
      "advanceOn": "minute"
    }
  },
  "entities": {
    "0": {
      "primitive": "empty_tile",
      "variant": "soil-gap",
      "color": "#8B7355",
      "label": "Empty",
      "idleAnimation": "none",
      "expression": null
    },
    "1": {
      "primitive": "fruit",
      "variant": "fresh-orange",
      "color": "#FFA62B",
      "label": "Fresh",
      "idleAnimation": "gentle_bounce",
      "expression": "nervous"
    },
    "2": {
      "primitive": "fruit",
      "variant": "rotten-orange",
      "color": "#7A9E3A",
      "label": "Rotten",
      "idleAnimation": "sick_wobble",
      "expression": "derpy-sick"
    }
  },
  "eventBindings": {
    "init": {
      "effect": "cell_pulse",
      "durationMs": 450,
      "color": "#FFFFFF",
      "explanation": "Reveal the initial grid while preserving empty, fresh, and rotten cells.",
      "targetReaction": null,
      "camera": null
    },
    "enqueue": {
      "effect": "queue_glow",
      "durationMs": 300,
      "color": "#29B6F6",
      "explanation": "Mark each rotten orange as it enters the BFS queue.",
      "targetReaction": null,
      "camera": null
    },
    "dequeue": {
      "effect": "bounce",
      "durationMs": 260,
      "color": "#AB47BC",
      "explanation": "Bounce the rotten orange currently removed from the queue.",
      "targetReaction": null,
      "camera": null
    },
    "cell_update": {
      "effect": "infection_poof",
      "durationMs": 480,
      "color": "#8E24AA",
      "explanation": "Show a fresh orange becoming rotten at its recorded minute.",
      "targetReaction": "panic_squish",
      "camera": "brief_focus"
    },
    "done": {
      "effect": "result_reveal",
      "durationMs": 650,
      "color": "#66BB6A",
      "explanation": "Reveal the traced minimum minutes, or impossibility when fresh oranges remain.",
      "targetReaction": null,
      "camera": null
    }
  },
  "resultChoreography": {
    "success": {
      "effect": "confetti",
      "entityReaction": "bad_dance",
      "explanation": "Celebrate when the returned minutes match the expected answer."
    },
    "failure": {
      "effect": "failure_deflate",
      "entityReaction": "confused_stare",
      "explanation": "Deflate when the result does not match the expected answer."
    }
  },
  "intro": [
    {
      "action": "show_title",
      "durationMs": 700,
      "text": "Rotting Oranges — Multi-Source BFS"
    },
    {
      "action": "show_grid",
      "durationMs": 600,
      "text": "Fresh oranges are bright, rotten oranges are sickly green, and empty cells are soil."
    },
    {
      "action": "highlight_sources",
      "durationMs": 650,
      "text": "All initially rotten oranges begin in the BFS queue at minute 0."
    }
  ],
  "published": true
}
